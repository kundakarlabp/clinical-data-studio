# Clinical Data Studio safe example configuration.
# Copy to .env on the deployment server and replace every CHANGE_ME value.

CDS_ENV=production
CDS_HOST=0.0.0.0
CDS_PORT=8765
CDS_SECRET_KEY=CHANGE_ME_generate_64_random_characters

CDS_DATABASE_BACKEND=postgres
POSTGRES_PASSWORD=CHANGE_ME_database_password
DATABASE_URL=postgresql://clinical:CHANGE_ME_database_password@db:5432/clinical_data_studio

CDS_REQUIRE_HTTPS=true
CDS_PUBLIC_BASE_URL=https://your-domain.example
CDS_DATA_DIR=/app/data
CDS_BACKUP_DIR=/app/backups
CDS_BACKUP_PASSPHRASE=CHANGE_ME_long_backup_passphrase
CDS_UPLOAD_DIR=/app/uploads
CDS_MAX_UPLOAD_MB=24

CDS_AI_PROVIDER=local
CDS_AI_ENABLED=false
CDS_AI_ALLOW_PHI=false
CDS_AI_MULTIMODAL=false
CDS_AI_MODEL=gpt-5.2
CDS_AI_TRANSCRIBE_MODEL=gpt-4o-transcribe
CDS_AI_MAX_FILE_MB=8
CDS_AI_MONTHLY_BUDGET_LIMIT=
OPENAI_API_KEY=

CDS_LOG_LEVEL=INFO
CDS_LOG_DIR=/app/logs

CDS_ADMIN_USERNAME=admin
CDS_ADMIN_PASSWORD=CHANGE_ME_long_admin_password
CDS_ADMIN_DISPLAY_NAME=Study Administrator
